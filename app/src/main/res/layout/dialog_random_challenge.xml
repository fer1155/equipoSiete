<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="36dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/card_dialog"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="56dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dialog_challenge"
            android:orientation="vertical"
            android:paddingTop="72dp"
            android:paddingBottom="64dp"
            android:paddingHorizontal="24dp">

            <TextView
                android:id="@+id/txt_challenge_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Aquí va el reto..."
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.3" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <FrameLayout
        android:id="@+id/pokemon_circle_container"
        android:layout_width="112dp"
        android:layout_height="112dp"
        android:background="@drawable/bg_pokemon_circle"
        android:elevation="8dp"
        app:layout_constraintEnd_toEndOf="@id/card_dialog"
        app:layout_constraintStart_toStartOf="@id/card_dialog"
        app:layout_constraintTop_toTopOf="@id/card_dialog"
        android:layout_marginTop="-56dp">

        <ImageView
            android:id="@+id/img_pokemon"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_gravity="center"
            android:scaleType="centerCrop"
            android:contentDescription="Pokémon aleatorio" />

    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_close_dialog"
        android:layout_width="160dp"
        android:layout_height="48dp"
        android:text="Cerrar"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="16sp"
        app:backgroundTint="#FF840B"
        app:cornerRadius="12dp"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="@id/card_dialog"
        app:layout_constraintEnd_toEndOf="@id/card_dialog"
        app:layout_constraintStart_toStartOf="@id/card_dialog"
        android:layout_marginBottom="-24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>