<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="viewModel"
            type="com.example.myapplication.ui.viewmodels.MainViewModel" />
    </data>

    <androidx.cardview.widget.CardView
        android:id="@+id/custom_toolbar_card"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        app:cardBackgroundColor="#000000"
        app:cardCornerRadius="32dp"
        app:cardElevation="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <ImageButton
                android:id="@+id/btn_star"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Favoritos"
                android:src="@drawable/star"
                app:tint="#FF840B" />

            <ImageButton
                android:id="@+id/btn_sound"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Sonido"
                android:onClick="@{() -> viewModel.toggleSound()}"
                android:src="@{safeUnbox(viewModel.isSoundEnabled) ? @drawable/sound : @drawable/no_sound}"
                app:tint="#FF840B" />

            <ImageButton
                android:id="@+id/btn_info"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Información"
                android:src="@drawable/info"
                app:tint="#FF840B" />

            <ImageButton
                android:id="@+id/btn_add"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Agregar"
                android:src="@drawable/add"
                app:tint="#FF840B" />

            <ImageButton
                android:id="@+id/btn_share"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Compartir"
                android:src="@drawable/share"
                app:tint="#FF840B" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</layout>